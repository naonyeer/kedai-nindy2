# Digiflazz API credentials. Leave blank to use mock price-list (demo mode).
# Get them from https://digiflazz.com/ → Pengaturan Koneksi API.
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=

# Set to "true" to send real production transactions. Default "false" sends
# `testing: true` so /v1/transaction returns sandbox responses without
# touching saldo. Use the test cases in src/app/dashboard/TembakTab.js.
DIGIFLAZZ_PROD=false

# Webhook HMAC-SHA1 secret (Pengaturan Koneksi API → Webhook). Required
# only if you've configured Digiflazz to call /api/digiflazz/webhook.
DIGIFLAZZ_WEBHOOK_SECRET=

# Password for /dashboard. Defaults to "171202" if unset (legacy value from
# the old hardcoded check).
ADMIN_PASSWORD=171202
